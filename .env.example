# Copie para .env e preencha os valores reais
# NUNCA comite o .env — ele já está no .gitignore

# Banco de dados
DATABASE_URL=postgresql://om_user:TROQUE_A_SENHA@localhost:5432/om_database

# JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=TROQUE_POR_SEGREDO_ALEATORIO_DE_64_CHARS

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://mova.omaproject.com.br,https://e3.omaproject.com.br

# Modo de produção (desliga debug, verbose errors)
FLASK_ENV=production

# Rate limiter — Redis para produção (evita reset dos contadores no restart)
# Instale: pip install flask-limiter[redis]
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Registro público de professores (padrão: desabilitado)
REGISTRO_PUBLICO=false
